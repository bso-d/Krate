# ── ZK observability configuration ──────────────────────────────────────────
# Copied to .env on first `kafka monitor up`. Safe defaults for a single host.

# Grafana admin login (change before exposing beyond localhost)
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# Host ports
GRAFANA_PORT=3000
PROM_PORT=9090

# Prometheus on-disk retention
PROM_RETENTION=15d
